# Govardhan Goshala - Render Deployment Environment Template
# Copy these values into Render Dashboard → Environment Variables

# =============================================================================
# REQUIRED: Production Environment
# =============================================================================
NODE_ENV=production

# =============================================================================
# REQUIRED: MongoDB Atlas Connection
# Get this from MongoDB Atlas → Connect → Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# =============================================================================
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/goshala?retryWrites=true&w=majority
MONGODB_DB=goshala

# =============================================================================
# REQUIRED: NextAuth Configuration
# Generate secrets: https://generate-secret.vercel.app/32
# NEXTAUTH_URL will be your Render app URL (e.g., https://goshala-app.onrender.com)
# =============================================================================
NEXTAUTH_URL=https://goshala-app.onrender.com
NEXTAUTH_SECRET=YOUR_GENERATED_SECRET_HERE_MIN_32_CHARS
JWT_SECRET=YOUR_GENERATED_SECRET_HERE_MIN_32_CHARS

# =============================================================================
# REQUIRED: Redis Cache (Upstash)
# Get these from Upstash Dashboard → Select Database → Copy Details
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN_HERE

# =============================================================================
# OPTIONAL: Twilio SMS/WhatsApp (if using notifications)
# Get from https://www.twilio.com/console
# =============================================================================
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_WHATSAPP_NUMBER=+14155238886

# =============================================================================
# OPTIONAL: Razorpay (if using payment integration)
# Get from https://dashboard.razorpay.com
# =============================================================================
# RAZORPAY_KEY_ID=your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret

# =============================================================================
# OPTIONAL: Email Configuration (Nodemailer)
# =============================================================================
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# =============================================================================
# OPTIONAL: Sentry (Error Tracking)
# Get from https://sentry.io
# =============================================================================
# SENTRY_DSN=https://key@sentry.io/project-id
# SENTRY_ENVIRONMENT=production

# =============================================================================
# OPTIONAL: Advanced Settings
# =============================================================================
# MONGODB_TLS=true
# MONGODB_TLS_ALLOW_INVALID=false
# LOG_LEVEL=info

# =============================================================================
# HOW TO USE THIS FILE
# =============================================================================
# 1. Replace all placeholder values (YOUR_XXXXX) with actual values
# 2. Go to Render Dashboard → Your Service → Environment
# 3. Add each variable one by one, OR
# 4. Use the "Bulk Update" button to paste all variables at once
# 5. Click "Save" or "Redeploy" to apply changes
# 6. Check logs to verify deployment
